# Vercel の環境変数に以下を設定する（.envにコピーしてローカル開発にも使える）

# Claude API キー（あなたが持つキー。ユーザーは入力不要になる）
VITE_CLAUDE_API_KEY=sk-ant-...

# 招待コード（カンマ区切りで複数設定可能）
VITE_INVITE_CODES=CORE2026,FRIEND01,FRIEND02

# Google OAuth Client ID (Gmail 連携で使用)
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアントID (ウェブアプリ) を作成
# 承認済みのJavaScript生成元に https://core-prism-app.vercel.app と http://localhost:5173 を追加
# 必要なスコープ: gmail.readonly / gmail.send / gmail.modify
VITE_GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# X (Twitter) OAuth 2.0 Client ID — 投稿生成スタジオで使用
# https://developer.twitter.com/ → Project → User authentication settings
# Type of App: Public client (Native App), OAuth 2.0 with PKCE 必須
# Callback URL: https://core-prism-app.vercel.app/ と http://localhost:5181/
# Scopes: tweet.read tweet.write users.read offline.access
VITE_X_CLIENT_ID=xxxxxxxxxxxxxxxxx

# OpenAI API キー — 画像生成 (DALL-E 3) で使用 (任意)
# 未設定の場合は Pollinations.ai (Flux model、無料) にフォールバック
# https://platform.openai.com/api-keys で発行
VITE_OPENAI_API_KEY=sk-...
