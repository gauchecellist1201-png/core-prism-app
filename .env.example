# Vercel の環境変数に以下を設定する（.envにコピーしてローカル開発にも使える）

# Claude API キー（あなたが持つキー。ユーザーは入力不要になる）
VITE_CLAUDE_API_KEY=sk-ant-...

# 招待コード（カンマ区切りで複数設定可能）
VITE_INVITE_CODES=CORE2026,FRIEND01,FRIEND02

# Google OAuth Client ID (Gmail 連携で使用)
VITE_GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# X (Twitter) OAuth 2.0 Client ID — 投稿生成スタジオで使用
VITE_X_CLIENT_ID=xxxxxxxxxxxxxxxxx

# OpenAI API キー — 画像生成 (DALL-E 3) で使用 (任意)
VITE_OPENAI_API_KEY=sk-...

# ─── Stripe 本番接続 (第4弾-2) ──────────────────────────────────
# Stripe ダッシュボード https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Stripe Webhook ダッシュボード > エンドポイント > シークレット
# エンドポイント URL: https://core-prism-app.vercel.app/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# Iris プラン Price ID (Stripe ダッシュボード > 商品 > 料金から取得)
STRIPE_PRICE_LITE=price_...
STRIPE_PRICE_STANDARD=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_STUDIO=price_...

# Prism プラン Price ID
STRIPE_PRICE_PRISM_STARTER=price_...
STRIPE_PRICE_PRISM_STANDARD=price_...
STRIPE_PRICE_PRISM_EXCLUSIVE=price_...

# ─── Resend メール通知 (第4弾-2) ────────────────────────────────
# https://resend.com/api-keys で発行
RESEND_API_KEY=re_...
# 送信元メールアドレス (Resend でドメイン認証済みのものを使用)
EMAIL_FROM=noreply@coreprism.app
