# Vercel の環境変数に以下を設定する（.envにコピーしてローカル開発にも使える）

# Claude API キー（あなたが持つキー。ユーザーは入力不要になる）
VITE_CLAUDE_API_KEY=sk-ant-...

# 招待コード（カンマ区切りで複数設定可能）
VITE_INVITE_CODES=CORE2026,FRIEND01,FRIEND02

# Google OAuth Client ID (Gmail 連携で使用)
# Google Cloud Console > 認証情報 > OAuth 2.0 クライアントID (ウェブアプリ) を作成
# 承認済みのJavaScript生成元に https://core-prism-app.vercel.app と http://localhost:5173 を追加
# 必要なスコープ: gmail.readonly / gmail.send / gmail.modify
VITE_GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com

# X (Twitter) OAuth 2.0 Client ID — 投稿生成スタジオで使用
# https://developer.twitter.com/ → Project → User authentication settings
# Type of App: Public client (Native App), OAuth 2.0 with PKCE 必須
# Callback URL: https://core-prism-app.vercel.app/ と http://localhost:5181/
# Scopes: tweet.read tweet.write users.read offline.access
VITE_X_CLIENT_ID=xxxxxxxxxxxxxxxxx

# OpenAI API キー — 画像生成 (DALL-E 3) で使用 (任意)
# 未設定の場合は Pollinations.ai (Flux model、無料) にフォールバック
# https://platform.openai.com/api-keys で発行
VITE_OPENAI_API_KEY=sk-...

# ─── Stripe 本番課金 ───
# 未設定の場合は CheckoutModal が自動的にテストモード (¥0) にフォールバック
# オーナー向け診断ページ: /master/stripe-status (master key 必須)
#
# 取得手順:
#   1. https://dashboard.stripe.com/apikeys → シークレットキー
#   2. https://dashboard.stripe.com/products → 7 商品を作成 (Iris 4 + Prism 3)
#   3. 各商品に「月額」+「年額」の Price を作成 (年額 = 月額 × 10 で 2 ヶ月分お得)
#   4. Webhook エンドポイント (/api/stripe/webhook) を Stripe Dashboard に登録 → 署名 secret 取得

# Stripe シークレットキー (Vercel サーバ環境変数に設定。VITE_ プレフィックス不要)
STRIPE_SECRET_KEY=sk_live_...

# Stripe Webhook シークレット (stripe listen で取得、または Webhook エンドポイントから)
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Iris プラン (4 プラン × 2 周期 = 8 個) ───
# Iris は個人クリエイター向け。Lite → Standard → Pro → Studio
STRIPE_PRICE_LITE=price_...                 # Iris Lite      ¥1,980/月
STRIPE_PRICE_LITE_YEARLY=price_...          # Iris Lite      ¥19,800/年
STRIPE_PRICE_STANDARD=price_...             # Iris Standard  ¥4,980/月
STRIPE_PRICE_STANDARD_YEARLY=price_...      # Iris Standard  ¥49,800/年
STRIPE_PRICE_PRO=price_...                  # Iris Pro       ¥9,800/月
STRIPE_PRICE_PRO_YEARLY=price_...           # Iris Pro       ¥98,000/年
STRIPE_PRICE_STUDIO=price_...               # Iris Studio    ¥29,800/月
STRIPE_PRICE_STUDIO_YEARLY=price_...        # Iris Studio    ¥298,000/年

# ─── Prism プラン (3 プラン × 2 周期 = 6 個) ───
# Prism は法人 / チーム向け。Starter → Standard → Exclusive
STRIPE_PRICE_PRISM_STARTER=price_...           # Prism Starter   ¥4,980/月
STRIPE_PRICE_PRISM_STARTER_YEARLY=price_...    # Prism Starter   ¥49,800/年
STRIPE_PRICE_PRISM_STANDARD=price_...          # Prism Standard  ¥9,800/月
STRIPE_PRICE_PRISM_STANDARD_YEARLY=price_...   # Prism Standard  ¥98,000/年
STRIPE_PRICE_PRISM_EXCLUSIVE=price_...         # Prism Exclusive ¥29,800/月
STRIPE_PRICE_PRISM_EXCLUSIVE_YEARLY=price_...  # Prism Exclusive ¥298,000/年

# ─── Resend メール通知 (第4弾の2: メール通知) ───
# 未設定の場合はメール送信をスキップ (UI は止まらない)

# Resend API キー (https://resend.com でアカウント作成 → API Keys)
RESEND_API_KEY=re_...

# 送信元メールアドレス (Resend でドメイン認証が必要)
EMAIL_FROM=noreply@coreprism.app

# ─── Slack / Discord 統合 (Phase 5-1: Webhook 送信) ───
# Webhook URL はユーザーが UI (IntegrationsHub) から登録するため不要。
# 以下は受信 (Slack スラッシュコマンド) に使用する。

# Slack Signing Secret — /api/integrations/inbound で署名検証に使用
# Slack App 管理画面 > Basic Information > App Credentials > Signing Secret
SLACK_SIGNING_SECRET=...

# Discord Bot Token — Bot 経由の送信が必要な場合のみ設定 (Webhook のみなら不要)
DISCORD_BOT_TOKEN=...
